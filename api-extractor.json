{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",

  // Use the main entry's type definitions emitted by tsup as input (subpath tracking is a future extension).
  "mainEntryPointFilePath": "<projectFolder>/dist/index.d.ts",

  "bundledPackages": [],

  "compiler": {
    "tsconfigFilePath": "<projectFolder>/tsconfig.json"
  },

  // Record the public API surface in etc/relaybox.api.md; review diffs and detect breaking changes.
  "apiReport": {
    "enabled": true,
    "reportFileName": "relaybox.api.md",
    "reportFolder": "<projectFolder>/etc/"
  },

  "docModel": { "enabled": false },
  "dtsRollup": { "enabled": false },
  "tsdocMetadata": { "enabled": false },

  "messages": {
    "extractorMessageReporting": {
      // Warn when internal types leak into the public API (catch it before release).
      "ae-forgotten-export": { "logLevel": "warning" },
      "ae-incompatible-release-tags": { "logLevel": "warning" }
    },
    "tsdocMessageReporting": {
      "default": { "logLevel": "warning" }
    }
  }
}
