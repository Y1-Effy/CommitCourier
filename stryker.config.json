{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.mutation.config.ts"
  },
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "reporters": ["clear-text", "progress", "html"],
  "comment": "Focus on core: pure, logic-dense, and cheap to mutate. Expand to all of src once stable.",
  "mutate": ["src/core/**/*.ts", "!src/core/index.ts", "!src/core/types.ts"],
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 70
  }
}
