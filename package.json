{
  "name": "commitcourier",
  "version": "0.1.0",
  "description": "Transactional Outbound Webhook delivery for Node.js/TypeScript, backed by your existing PostgreSQL.",
  "license": "MIT",
  "author": "Y1-Effy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Y1-Effy/CommitCourier.git"
  },
  "bugs": {
    "url": "https://github.com/Y1-Effy/CommitCourier/issues"
  },
  "homepage": "https://github.com/Y1-Effy/CommitCourier#readme",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "require": {
        "types": "./dist/core/index.d.cts",
        "default": "./dist/core/index.cjs"
      }
    },
    "./store/pg": {
      "import": {
        "types": "./dist/store/pg.d.ts",
        "default": "./dist/store/pg.js"
      },
      "require": {
        "types": "./dist/store/pg.d.cts",
        "default": "./dist/store/pg.cjs"
      }
    },
    "./store/knex": {
      "import": {
        "types": "./dist/store/knex.d.ts",
        "default": "./dist/store/knex.js"
      },
      "require": {
        "types": "./dist/store/knex.d.cts",
        "default": "./dist/store/knex.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:lang": "node scripts/check-no-cjk.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:coverage": "vitest run --coverage",
    "test:types": "vitest --typecheck --run --project unit",
    "test:mutation": "stryker run",
    "test:watch": "vitest",
    "lint:publish": "publint && attw --pack .",
    "api:check": "api-extractor run",
    "api:update": "api-extractor run --local",
    "check": "npm run typecheck && npm run lint && npm run lint:lang && npm run test:unit",
    "prepublishOnly": "npm run check && npm run build && npm run lint:publish && npm run api:check"
  },
  "dependencies": {
    "p-limit": "^6.2.0",
    "undici": "^7.0.0"
  },
  "peerDependencies": {
    "knex": ">=3",
    "pg": ">=8"
  },
  "peerDependenciesMeta": {
    "knex": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.48.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "prettier": "^3.4.2",
    "publint": "^0.3.0",
    "testcontainers": "^12.0.3",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "webhook",
    "outbox",
    "transactional-outbox",
    "postgres",
    "standard-webhooks",
    "delivery",
    "ssrf"
  ]
}
